# Phase 5 (cloud) environment — copy to .env.local for local dev, and set the same
# in Vercel project settings. NEVER commit real values. The app stays local-first
# until VITE_SUPABASE_URL is set.

# --- server only (Vercel serverless functions; keep SECRET) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=any-long-random-string

# --- client (build-time flag to switch the data layer to the cloud) ---
# Set this to your Supabase URL (any truthy value enables cloud mode).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
